<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>perception_bringup</name>
  <version>0.0.0</version>
  <description>Bringup Package for Perception</description>
  <maintainer email="hello@watonomous.ca">WATonomous</maintainer>
  <license>Apache 2.0</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <!-- Launched nodes and component container (zero-copy is intra-process in container) -->
  <exec_depend>rmw_zenoh_cpp</exec_depend>
  <exec_depend>patchworkpp</exec_depend>
  <exec_depend>wato_lifecycle_manager</exec_depend>
  <exec_depend>rclcpp_components</exec_depend>
  <exec_depend>sensor_interfacing</exec_depend>
  <exec_depend>camera_sync</exec_depend>
  <exec_depend>deep_object_detection</exec_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
