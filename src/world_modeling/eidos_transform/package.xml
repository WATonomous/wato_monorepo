<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>eidos_transform</name>
  <version>0.1.0</version>
  <description>EKF-based multi-source odometry fusion and TF broadcasting for eidos</description>
  <maintainer email="infra@watonomous.ca">WATonomous</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>rclcpp_lifecycle</depend>
  <depend>tf2</depend>
  <depend>tf2_ros</depend>
  <depend>tf2_geometry_msgs</depend>
  <depend>nav_msgs</depend>
  <depend>geometry_msgs</depend>
  <depend>sensor_msgs</depend>
  <depend>eidos_msgs</depend>
  <depend>pluginlib</depend>

  <build_depend>eigen</build_depend>
  <build_depend>gtsam</build_depend>

  <exec_depend>eigen</exec_depend>
  <exec_depend>gtsam</exec_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
