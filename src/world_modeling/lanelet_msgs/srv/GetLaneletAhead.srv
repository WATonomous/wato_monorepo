# GetLaneletAhead.srv
# Get lanelets reachable from a given position and heading.
#
# Finds the nearest lanelet to the query point using heading alignment,
# then returns all BFS-reachable lanelets within the specified radius.

geometry_msgs/Point position
float64 heading_rad
float64 radius_m

---
bool success

# Error description if success is false
# Values: "map_not_loaded", "lanelet_not_found"
string error_message

# Reachable lanelets from the query position
LaneletAhead lanelet_ahead
