  </class>
  <class name="eidos::EuclideanDistanceLoopClosureFactor" type="eidos::EuclideanDistanceLoopClosureFactor" base_class_type="eidos::FactorPlugin">
    <description>Euclidean distance loop closure (GICP between keyframes)</description>
  </class>
  <class name="eidos::ImuFactor" type="eidos::ImuFactor" base_class_type="eidos::FactorPlugin">
    <description>IMU preintegration factor (ImuFactor + bias BetweenFactor)</description>
  </class>
  <class name="eidos::MotionModelFactor" type="eidos::MotionModelFactor" base_class_type="eidos::FactorPlugin">
    <description>Motion model between-factor via eidos_transform predict service</description>
  </class>
