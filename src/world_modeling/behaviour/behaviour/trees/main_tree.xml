<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <include path="subtrees/intersection/root.xml" />
  <include path="subtrees/lane_navigation/root.xml" />
  <BehaviorTree ID="MainTree">
    <ParallelAll max_failures="-1">
      <Fallback name="Root Fallback">

        <!-- Reactive Sequence to check if we have a valid goal and route -->
        <ReactiveSequence name="Core Navigation Sequence">
          <!-- Ensure goal exists -->
          <GoalExist goal_point="{goal_point}" />

          <!-- Ensure path exists -->
          <Fallback name="Ensure Route">

            <!-- Essentially do we need to get the route -->
            <Sequence name="IsGlobalRouteValid">
              <GlobalRouteExist route="{global_route}" />
              <GoalLaneletExist goal_lanelet="{goal_lanelet}" />
              <!-- <EgoOnRoute route_index_map="{global_route_index_map}"
              lane_ctx="{current_lane_ctx}" /> -->
            </Sequence>

            <Sequence name="Get Route">
              <!-- If the reason that IsGlobalRouteValid failed was due to missing ports dont get
              route -->
              <Inverter>
                <IsErrorMessage msg="{ego_on_route_error_msg}" expected="missing_port:lane_ctx" />
              </Inverter>
              <Fallback>

                <GetShortestRoute route="{global_route}" route_index_map="{global_route_index_map}"
                  route_lanelet_ids="{global_route_lanelet_ids}" goal_lanelet="{goal_lanelet}"
                  error_message="{get_shortest_route_error_msg}"
                  service_name="/world_modeling/get_shortest_route" />

                <Sequence name="Set Route">
                  <Fallback name="CheckSpecificErrors">
                    <IsErrorMessage msg="{get_shortest_route_error_msg}" expected="ego_not_on_route" />
                    <IsErrorMessage msg="{get_shortest_route_error_msg}" expected="no_active_route" />
                  </Fallback>

                  <RetryUntilSuccessful num_attempts="8">
                    <RateController hz="1.0">
                      <SetRoute goal_point="{goal_point}" service_name="/world_modeling/set_route" />
                    </RateController>
                  </RetryUntilSuccessful>

                  <Delay delay_msec="10000">
                    <GetShortestRoute route="{global_route}"
                      route_index_map="{global_route_index_map}"
                      route_lanelet_ids="{global_route_lanelet_ids}" goal_lanelet="{goal_lanelet}"
                      error_message="{get_shortest_route_error_msg}"
                      service_name="/world_modeling/get_shortest_route" />
                  </Delay>

                </Sequence>
              </Fallback>
            </Sequence>
          </Fallback>

          <!-- NAVIGATION -->
          <SubTree ID="LaneNavigationSubTree" _autoremap="true" />
          <!-- NAVIGATION -->

        </ReactiveSequence>

        <!-- If no goal exists or goal is reached or we failed to get route -->
        <ExecuteBehaviour behaviour="standby" topic_name="execute_behaviour" />

      </Fallback>

      <!-- INTERSECTION -->
      <SubTree ID="IntersectionSubTree" />
      <!-- INTERSECTION -->
    </ParallelAll>
  </BehaviorTree>
</root>
