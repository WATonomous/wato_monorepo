<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <include path="subtrees/intersection/root.xml" />
  <include path="subtrees/lane_navigation/root.xml" />
  <BehaviorTree ID="MainTree">
    <ParallelAll max_failures="-1">
      <ReactiveFallback name="Goal Manager">
        <Sequence name="Update Route On Goal Change">
          <Fallback name="Ensure Pending Goal">
            <GoalExist goal_point="{pending_gp}" />

            <Sequence>
              <GoalExist goal_point="{requested_gp}" />
              <SetPendingGoal
                requested_goal_point="{requested_gp}"
                out_pending_goal_point="{pending_gp}"
                out_requested_goal_point="{requested_gp}" />
            </Sequence>
          </Fallback>

          <Fallback name="Try Set New Goal">
            <Sequence>
              <RetryUntilSuccessful num_attempts="8">
                <RateController hz="1.0">
                  <SetRoute
                    goal_point="{pending_gp}"
                    error_message="{set_route_error_msg}"
                    service_name="/world_modeling/set_route" />
                </RateController>
              </RetryUntilSuccessful>

              <RetryUntilSuccessful num_attempts="8">
                <RateController hz="1.0">
                  <GetShortestRoute
                    route="{staged_global_route}"
                    route_index_map="{staged_global_route_index_map}"
                    route_lanelet_ids="{staged_global_route_lanelet_ids}"
                    goal_lanelet="{staged_goal_lanelet}"
                    error_message="{get_shortest_route_error_msg}"
                    service_name="/world_modeling/get_shortest_route" />
                </RateController>
              </RetryUntilSuccessful>

              <SetNewGoal
                goal_point="{pending_gp}"
                goal_lanelet="{staged_goal_lanelet}"
                global_route="{staged_global_route}"
                global_route_index_map="{staged_global_route_index_map}"
                global_route_lanelet_ids="{staged_global_route_lanelet_ids}"
                out_goal_point="{goal_point}"
                out_goal_lanelet="{goal_lanelet}"
                out_global_route="{global_route}"
                out_global_route_index_map="{global_route_index_map}"
                out_global_route_lanelet_ids="{global_route_lanelet_ids}" />
            </Sequence>

            <LogFailure message="failed to set new goal point" error_message="{set_route_error_msg}" />
          </Fallback>

          <ClearPendingGoalPoint out_pending_goal_point="{pending_gp}" />
        </Sequence>

        <GoalExist goal_point="{requested_gp}" />
      </ReactiveFallback>

      <Fallback name="Root Fallback">

        <!-- Reactive Sequence to check if we have a valid goal and route -->
        <ReactiveSequence name="Core Navigation Sequence">
          <GoalExist goal_point="{goal_point}" />
          <GlobalRouteExist route="{global_route}" />
          <GoalLaneletExist goal_lanelet="{goal_lanelet}" />

          <!-- NAVIGATION -->
          <SubTree ID="LaneNavigationSubTree" _autoremap="true" />
          <!-- NAVIGATION -->

        </ReactiveSequence>

        <!-- If no goal exists or goal is reached or we failed to get route -->
        <ExecuteBehaviour behaviour="standby" topic_name="execute_behaviour" />

      </Fallback>

      <!-- INTERSECTION -->
      <SubTree ID="IntersectionSubTree" />
      <!-- INTERSECTION -->
    </ParallelAll>
  </BehaviorTree>
</root>
