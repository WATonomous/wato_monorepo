<root BTCPP_format="4" main_tree_to_execute="YieldSubTree">

  <BehaviorTree ID="YieldSubTree">
    <Fallback name="Handle Yield">

      <Sequence name="Yield Ego Priority Latched">
        <RegElemEgoPriority ego_priority="{yield.ego_priority}" />
        <Fallback name="DespawnIfNeeded">
          <Inverter>
            <WallIdExist wall_id="{yield.wall_id}" />
          </Inverter>
          <DespawnWall
            wall_id="{yield.wall_id}"
            out_wall_id="{yield.wall_id}"
            error_message="{yield.despawn_wall_error_msg}"
            service_name="/world_modeling/despawn_wall" />
        </Fallback>
      </Sequence>

      <Sequence name="Wait For Yield Turn">

        <!-- compute stop/yield line pose and spawn wall (only if not already spawned) -->
        <Fallback name="SpawnIfNeeded">
          <WallIdExist wall_id="{yield.wall_id}" />
          <Sequence>
            <Fallback name="GetYieldWallPose">
              <GetStopLinePose
                reg_elem="{yield_sign}"
                lane_ctx="{@current_lane_ctx}"
                map_frame="{@map_frame}"
                pose="{yield.wall_pose}"
                error_message="{yield.get_stop_line_pose_error_msg}" />
              <GetLaneletEndPose
                lane_ctx="{@current_lane_ctx}"
                map_frame="{@map_frame}"
                pose="{yield.wall_pose}"
                error_message="{yield.get_lanelet_end_pose_error_msg}" />
            </Fallback>
            <SpawnWall
              pose="{yield.wall_pose}"
              tf_buffer="{@tf_buffer}"
              pose_frame="{@map_frame}"
              width="{@bt.intersection_wall_of_doom_width}"
              length="{@bt.intersection_wall_of_doom_length}"
              wall_id="{yield.wall_id}"
              error_message="{yield.spawn_wall_error_msg}"
              service_name="/world_modeling/spawn_wall" />
          </Sequence>
        </Fallback>

        <GetWorldObjectsSub
          objects="{yield.objects}"
          error_message="{yield.get_objects_error_msg}"
          topic_name="/world_modeling/world_objects_enriched" />

        <!-- wait until yield lanes are clear for a gap -->
        <YieldCanProceed
          active_traffic_control_element="{yield_sign}"
          active_traffic_control_lanelet_id="{active_traffic_control_lanelet_id}"
          objects="{yield.objects}"
          hypothesis_index="{@world_objects_hypothesis_index}" />

        <SetRegElemEgoPriority ego_priority="{yield.ego_priority}" />

        <!-- despawn wall once ego has earned priority -->
        <Fallback name="DespawnIfNeeded">
          <Inverter>
            <WallIdExist wall_id="{yield.wall_id}" />
          </Inverter>
          <DespawnWall
            wall_id="{yield.wall_id}"
            out_wall_id="{yield.wall_id}"
            error_message="{yield.despawn_wall_error_msg}"
            service_name="/world_modeling/despawn_wall" />
        </Fallback>
      </Sequence>
    </Fallback>
  </BehaviorTree>
</root>
