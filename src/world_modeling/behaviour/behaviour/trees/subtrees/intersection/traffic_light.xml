<root BTCPP_format="4" main_tree_to_execute="TrafficLightSubTree">
	<BehaviorTree ID="TrafficLightSubTree">
		<Sequence name="Handle Traffic Light">

			<!-- try to determine the traffic light state and act on it.
                 if anything fails (service, detection, etc.), the fallback
                 falls through to the fail safe wall spawn at the end. -->
			<Fallback name="Traffic Light Gate">

				<!-- green: despawn wall and succeed -->
				<Sequence name="Green">
					<GetWorldObjectsSub
						objects="{traffic_light.objects}"
						error_message="{traffic_light.get_objects_error_msg}"
						topic_name="/world_modeling/world_objects_enriched" />

					<GetTrafficLightState
						traffic_light="{traffic_light}"
						objects="{traffic_light.objects}"
						state_hypothesis_index="{@traffic_light_state_hypothesis_index}"
						out_traffic_light_state="{traffic_light.state}"
						error_message="{get_traffic_light_state_error_msg}" />

					<IsTrafficLightState traffic_light_state="{traffic_light.state}"
						expected="green" />

					<!-- only despawn if a wall was previously spawned, then clear wall_id -->
					<Fallback name="DespawnIfNeeded">
						<Inverter>
							<WallIdExist wall_id="{traffic_light.wall_id}" />
						</Inverter>
						<DespawnWall wall_id="{traffic_light.wall_id}"
							out_wall_id="{traffic_light.wall_id}"
							error_message="{traffic_light.despawn_wall_error_msg}"
							service_name="/world_modeling/despawn_wall" />
					</Fallback>
				</Sequence>

	                <Sequence name="Right Turn Yield Release Latched">
	                    <TrafficLightRightTurnLatched
	                        right_turn_latch="{traffic_light.right_turn_latch}" />
					<Fallback name="DespawnIfNeeded">
						<Inverter>
							<WallIdExist wall_id="{traffic_light.wall_id}" />
						</Inverter>
						<DespawnWall wall_id="{traffic_light.wall_id}"
							out_wall_id="{traffic_light.wall_id}"
							error_message="{traffic_light.despawn_wall_error_msg}"
							service_name="/world_modeling/despawn_wall" />
					</Fallback>
				</Sequence>

				<Sequence name="Right Turn Yield Release">
					<WallIdExist wall_id="{traffic_light.wall_id}" />
					<GetStopLinePose
						reg_elem="{traffic_light}"
						lane_ctx="{@current_lane_ctx}"
						map_frame="{@map_frame}"
						pose="{traffic_light.wall_pose}"
						error_message="{traffic_light.get_stop_line_pose_error_msg}" />
					<EgoNearStopLine
						ego_odom="{@ego_odom}"
						stop_line_pose="{traffic_light.wall_pose}"
						threshold_m="{@bt.stop_sign_ego_stop_line_threshold_m}" />
					<ReactiveSequence name="Require Full Stop">
						<EgoStopped
							ego_odom="{@ego_odom_incremental}"
							threshold_velocity="{@bt.ego_stopped_velocity_threshold}" />
						<WaitDuration duration_msec="5000" />
					</ReactiveSequence>
					<GetForwardLanelet
						lane_ctx="{@current_lane_ctx}"
						route_ahead="{@route_ahead}"
						lanelets_ahead="{@lanelets_ahead}"
						lanelets_ahead_index_map="{@lanelets_ahead_index_map}"
						out_lanelet="{traffic_light.forward_lanelet}" />
					<IsLaneletTurnDirection
						lanelet="{traffic_light.forward_lanelet}"
						expected="right" />
					<!-- TODO(WATonomous): Restore the right-of-way occupancy gate once
	                         traffic-light-associated right_of_way lanelets are available in
	                         the map / regulatory-element path. -->
					<GetWorldObjectsSub
						objects="{traffic_light.objects}"
						error_message="{traffic_light.get_objects_error_msg}"
						topic_name="/world_modeling/world_objects_enriched" />
					<GetRightOfWayLaneletIds
						lane_ctx="{@current_lane_ctx}"
						out_lanelet_ids="{traffic_light.right_of_way_lanelet_ids}" />
					<EmptyLanelets
						lanelet_ids="{traffic_light.right_of_way_lanelet_ids}"
						objects="{traffic_light.objects}"
						hypothesis_index="{@world_objects_hypothesis_index}" />
	                    <SetTrafficLightRightTurnLatch
	                        right_turn_latch="{traffic_light.right_turn_latch}"
	                        out_right_turn_latch="{traffic_light.right_turn_latch}" />

					<Fallback name="DespawnIfNeeded">
						<Inverter>
							<WallIdExist wall_id="{traffic_light.wall_id}" />
						</Inverter>
						<DespawnWall wall_id="{traffic_light.wall_id}"
							out_wall_id="{traffic_light.wall_id}"
							error_message="{traffic_light.despawn_wall_error_msg}"
							service_name="/world_modeling/despawn_wall" />
					</Fallback>
				</Sequence>

				<!-- fail safe: any non-green state or detection failure => spawn wall (only if not
				already spawned) -->
				<Fallback name="SpawnIfNeeded">
					<WallIdExist wall_id="{traffic_light.wall_id}" />
					<Sequence>
						<GetStopLinePose
							reg_elem="{traffic_light}"
							lane_ctx="{@current_lane_ctx}"
							map_frame="{@map_frame}"
							pose="{traffic_light.wall_pose}"
							error_message="{traffic_light.get_stop_line_pose_error_msg}" />
						<SpawnWall
							pose="{traffic_light.wall_pose}"
							tf_buffer="{@tf_buffer}"
							pose_frame="{@map_frame}"
							width="{@bt.intersection_wall_of_doom_width}"
							length="{@bt.intersection_wall_of_doom_length}"
							wall_id="{traffic_light.wall_id}"
							error_message="{traffic_light.spawn_wall_error_msg}"
							service_name="/world_modeling/spawn_wall" />
					</Sequence>
				</Fallback>

			</Fallback>

		</Sequence>
	</BehaviorTree>

</root>
