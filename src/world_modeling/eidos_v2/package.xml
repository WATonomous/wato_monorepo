<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>eidos_v2</name>
  <version>0.1.0</version>
  <description>Plugin-based LiDAR-Inertial-GNSS SLAM system (v2 architecture)</description>
  <maintainer email="infra@watonomous.ca">WATonomous</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>rclcpp_lifecycle</depend>
  <depend>sensor_msgs</depend>
  <depend>nav_msgs</depend>
  <depend>geometry_msgs</depend>
  <depend>visualization_msgs</depend>
  <depend>tf2</depend>
  <depend>tf2_ros</depend>
  <depend>tf2_geometry_msgs</depend>
  <depend>pcl_conversions</depend>
  <depend>eidos_msgs</depend>
  <depend>pluginlib</depend>

  <build_depend>libpcl-all-dev</build_depend>
  <build_depend>sqlite3_vendor</build_depend>
  <build_depend>gtsam</build_depend>
  <build_depend>eigen</build_depend>
  <build_depend>small_gicp_vendor</build_depend>

  <exec_depend>libpcl-all-dev</exec_depend>
  <exec_depend>sqlite3_vendor</exec_depend>
  <exec_depend>gtsam</exec_depend>
  <exec_depend>eigen</exec_depend>
  <exec_depend>small_gicp_vendor</exec_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
